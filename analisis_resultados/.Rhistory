# install.packages("tidyverse")
library(tidyverse)
# install.packages("readxl")
library(readxl)
# install.packages("silviculture")
library(silviculture)
df <- read_excel("Psylvestris_SCentral_SIberico_IBERO_IFN_3_parcelas.xlsx", sheet = "PiesMayores")
summary(df)
df <- read_excel("/media/aitor/7FB15A9C1FA8F1DA/trabajo/docencia/2025-26/FORESTALES_ordenacion/1_temas/4_bonus_modelizacion/Psylvestris_SCentral_SIberico_IBERO_IFN_3_parcelas.xlsx", sheet = "PiesMayores")
summary(df)
View(df)
df$dbh
df$altura_total
# stem biomass (biomasa del tronco) = 0.0154*d^2*h
df$biomasa_tronco_manual <- 0.0154 * df$dbh^2 * df$altura_total
df$biomasa_tronco_manual
# root biomass (biomasa de las raíces) = 0.130*d^2
df$biomasa_raiz <- 0.130 * df$dbh^2
df$biomasa_raiz
View(df)
# creamos la función
biomasa_tronco_psyl <- function(dbh, h) {
biomasa_tronco <- 0.0154 * dbh^2 * h
return(biomasa_tronco)
}
View(biomasa_tronco_psyl)
# probamos la función con distintos datos
biomasa_tronco_psyl(10, 20)
biomasa_tronco_psyl(dbh = c(10, 15, 30), h = c(20, 25, 35))
# probamos la función con nuestros datos
df$biomasa_tronco_funcion <- biomasa_tronco_psyl(dbh = df$dbh,
h = df$altura_total)
df$biomasa_tronco_funcion
View(df)
# probamos la función de silviculture (ver ayuda)
silv_predict_biomass(
diameter = 45,
height   = 22,
model    = eq_biomass_ruiz_peinado_2011(species = "Pinus sylvestris",
component = "stem")
)
# probamos la función con nuestros datos
df$biomasa_tronco_silv <- silv_predict_biomass(diameter = df$dbh,
height   = df$altura_total,
model    = eq_biomass_ruiz_peinado_2011(species = "Pinus sylvestris",
component = "stem"),
quiet = TRUE)
View(df)
